# App
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://yugantar.studio
NEXT_PUBLIC_OLD_APP_URL=https://www.stylesage.me

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/yugantar?retryWrites=true&w=majority

# Auth (must be at least 32 characters)
JWT_SECRET=replace_with_a_very_long_random_secret_at_least_32_chars

# Optional default admin bootstrap
DEFAULT_ADMIN_EMAIL=admin@yugantar.studio
DEFAULT_ADMIN_PASSWORD=replace_with_a_strong_password_min_12_chars

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=https://yugantar.studio/api/auth/callback/google
GOOGLE_OAUTH_STATE_SECRET=replace_with_a_separate_random_secret_at_least_32_chars

# Cloudinary (use CLOUDINARY_URL or the individual values)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Resend (order notification emails)
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
ORDER_ADMIN_EMAIL=piyushnegi.bca2022@imsuc.ac.in

# Optional SEO verification
GOOGLE_SITE_VERIFICATION=your_google_site_verification_token
